APP_NAME=AI Video Studio
API_HOST=0.0.0.0
API_PORT=8000

# Default demo backend. For real video generation set VIDEO_BACKEND to one of:
# comfyui, wan, cogvideox, hunyuan, ltx, local_open_video, diffusers_t2v, diffusers_i2v, external
MODEL_BACKEND=mock
VIDEO_BACKEND=mock
MODEL_PATH=

# Optional OpenAI GPT planning for short-drama script and shot refinement.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# External API backend placeholder.
EXTERNAL_API_URL=
EXTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# ComfyUI backend
# -----------------------------------------------------------------------------
# For production short-drama generation, use VIDEO_BACKEND=comfyui and the I2V
# workflow/profile below. The workflow file is intentionally a placeholder until
# you replace it with a real ComfyUI Save (API Format) export from your machine.
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=examples/workflows/comfyui_i2v_short_drama.workflow.json
COMFYUI_WORKFLOW_PROFILE_PATH=examples/workflows/comfyui_i2v_short_drama.profile.json

# Main recommended workflow: image-to-video short drama.
COMFYUI_I2V_WORKFLOW_PATH=examples/workflows/comfyui_i2v_short_drama.workflow.json
COMFYUI_I2V_PROFILE_PATH=examples/workflows/comfyui_i2v_short_drama.profile.json

# Optional text-to-video workflow. Configure these only after you add a real T2V
# API-format workflow and matching profile.
COMFYUI_T2V_WORKFLOW_PATH=examples/workflows/comfyui_t2v_short_drama.workflow.json
COMFYUI_T2V_PROFILE_PATH=examples/workflows/comfyui_t2v_short_drama.profile.json

COMFYUI_TIMEOUT_SECONDS=900
COMFYUI_POLL_INTERVAL_SECONDS=1.5
COMFYUI_OUTPUT_SUBDIR=comfyui_downloads

# Local open video models. Populate these with scripts/download_model_weights.py.
# Example: make models-wan && cat .env.models.local
WAN_MODEL_PATH=
WAN_MODEL_ID=
LTX_MODEL_PATH=
LTX_MODEL_ID=
COGVIDEOX_MODEL_PATH=
COGVIDEOX_MODEL_ID=
HUNYUAN_MODEL_PATH=
HUNYUAN_MODEL_ID=
LOCAL_VIDEO_MODEL_PATH=
LOCAL_VIDEO_MODEL_ID=
LOCAL_VIDEO_DEVICE=auto
LOCAL_VIDEO_DTYPE=auto
LOCAL_VIDEO_ALLOW_DEFAULT_DOWNLOAD=false
LOCAL_VIDEO_ALLOW_MOCK_FALLBACK=true
ENABLE_MODEL_CPU_OFFLOAD=true
ENABLE_ATTENTION_SLICING=true
ENABLE_VAE_TILING=true
ENABLE_VAE_SLICING=true

OUTPUT_DIR=data/outputs
UPLOAD_DIR=data/uploads
MAX_UPLOAD_MB=20
