.env
__pycache__/
*.pyc
.venv/
node_modules/
.next/
dist/

# Runtime data and generated media
data/outputs/*.mp4
data/uploads/*
data/logs/*
data/tasks/*.json
data/feedback/*.json
!data/outputs/.gitkeep
!data/uploads/.gitkeep
!data/logs/.gitkeep
!data/tasks/.gitkeep
!data/feedback/.gitkeep

# Real AI model weights must stay outside Git history.
# Use scripts/download_model_weights.py to populate these folders locally.
models/**
weights/**
checkpoints/**
*.ckpt
*.safetensors
*.bin
*.pt
*.pth
*.onnx
*.gguf
*.ggml
*.npz
*.tar
*.tar.gz
*.zip
*.7z
!models/.gitkeep
!weights/.gitkeep
!checkpoints/.gitkeep
!config/model_weights.example.json

.pytest_cache/
